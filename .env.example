# --- Solana ---
# RECOMMENDED: point this at Helius (Pro/Dev plan) — the public node rate-limits
# scan calls (getTokenLargestAccounts, etc.) and WS subscriptions.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Example: SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# --- Data enrichment (all optional; analyze_token degrades gracefully) ---
# DexScreener (free, no key) is the always-on default for market data.

# Birdeye — paid; adds total holder count + cross-check on liquidity/price.
BIRDEYE_API_KEY=

# Helius — Yellowstone/Geyser gRPC streaming (Phase-2.5 upgrade from WS logsSubscribe).
HELIUS_API_KEY=

# Zerion — cross-chain wallet/portfolio data. Used by the enrich_wallet skill on
# dev wallets, top holders, suspected alpha wallets. Free tier works.
ZERION_API_KEY=

# GMGN — smart-money + Pump.fun signals. Hits public quotation endpoints by
# default (best-effort, rate-limited). Set GMGN_API_KEY if you ever go paid.
GMGN_API_KEY=
GMGN_BASE_URL=

# Jupiter — public quote-api.jup.ag is free; set JUPITER_API_KEY to route to the
# Pro endpoint (api.jup.ag/swap/v1) with x-api-key header for higher RPS.
JUPITER_API_KEY=
JUPITER_BASE_URL=

# --- Brain (LLM provider for `kuro agent`) ---
# Options: glm (default) | anthropic | openai | codex
KURO_BRAIN=glm
# Override the per-provider default model. Leave empty to use the default.
#   glm default:       glm-4.5
#   anthropic default: claude-sonnet-4-6
#   openai default:    gpt-4o
KURO_MODEL=

# GLM (Zhipu) — primary brain. Native OpenAI-compatible function-calling.
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# Anthropic — used when KURO_BRAIN=anthropic
ANTHROPIC_API_KEY=

# OpenAI / any OpenAI-compatible provider — used when KURO_BRAIN=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Codex — used when KURO_BRAIN=codex. Reuses your `codex login` OAuth tokens
# from ~/.codex/auth.json against OpenAI's Responses API. Native function-
# calling (same as GLM/Anthropic), no separate API key needed.
#   KURO_CODEX_MODE = oauth (default) | subprocess
#     oauth      — reads ~/.codex/auth.json, calls api.openai.com/v1/responses
#     subprocess — fallback: spawns `codex exec`, parses <<TOOL>> markers (less reliable)
#   KURO_CODEX_AUTH_PATH — override the auth.json path (default: ~/.codex/auth.json)
#   KURO_CODEX_CMD / KURO_CODEX_ARGS — only used in subprocess mode
KURO_CODEX_MODE=oauth
KURO_CODEX_AUTH_PATH=
KURO_CODEX_CMD=codex
KURO_CODEX_ARGS=

# --- Executor (Rust hot-path) ---
KURO_EXECUTOR_URL=http://127.0.0.1:7777
KURO_BIND=127.0.0.1:7777
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles
KURO_KEYPAIR_PATH=./executor/keypair.json
KURO_STATE_PATH=./executor/state.json

# Risk caps — enforced INSIDE the executor, not just in the agent prompt.
# Defaults sized for the 0.5 SOL exploration bankroll (decided 2026-05-15).
# Raise only after the backtest harness shows positive hypothetical EV.
KURO_MAX_TRADE_SOL=0.02
KURO_DAILY_CAP_SOL=0.1
KURO_DRAWDOWN_KILL_PCT=20.0

# --- Autonomous mode (kuro autonomous) ---
# Master switch. Set to "true" to execute live; default = dry-run.
KURO_AUTONOMOUS_LIVE=false
KURO_POSITIONS_PATH=./executor/positions.json

# Entry policy
KURO_SNIPE_SOL=0.01
KURO_MAX_SLIPPAGE_BPS=1500
KURO_MAX_TOP10_PCT=60
KURO_MAX_ROUND_TRIP_LOSS_PCT=25
KURO_REQUIRE_RENOUNCED_FREEZE=true
KURO_REQUIRE_RENOUNCED_MINT=false
KURO_USE_JITO=true
KURO_JITO_TIP_SOL=0.0002

# Exit policy
KURO_TAKE_PROFIT_PCT=50
KURO_STOP_LOSS_PCT=30
KURO_MAX_HOLD_SECONDS=600
